{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs20"
    }
  ],
  "storage": {
    "rules": "storage.rules"
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "trazos-database",
          "appId": "1:756598503122:android:fd501b842c9cef10d05f0b",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "trazos-database",
          "configurations": {
            "android": "1:756598503122:android:fd501b842c9cef10d05f0b",
            "ios": "1:756598503122:ios:b3bdcad620ee67ddd05f0b",
            "web": "1:756598503122:web:599633eca71c88e3d05f0b"
          }
        }
      }
    }
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=0,must-revalidate"
          }
        ]
      },
      {
        "source": "/site.css",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=3600,must-revalidate"
          }
        ]
      },
      {
        "source": "/site.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=3600,must-revalidate"
          }
        ]
      },
      {
        "source": "/site.webmanifest",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=3600,must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/strava-callback",
        "destination": "/strava-callback.html"
      }
    ]
  }
}
