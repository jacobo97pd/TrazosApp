rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────
    function isAuth()          { return request.auth != null; }
    function isOwner(uid)      { return request.auth.uid == uid; }
    function isClubAdmin(clubId) {
      return get(/databases/$(database)/documents/clubs/$(clubId))
               .data.adminId == request.auth.uid;
    }
    function isClubMember(clubId) {
      return request.auth.uid in
        get(/databases/$(database)/documents/clubs/$(clubId)).data.members;
    }
    function onlyAttendeesChanged() {
      return request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['attendees']);
    }
    function isModerator() {
      return isAuth() &&
        (request.auth.token.get('moderator', false) == true ||
         request.auth.token.get('admin', false) == true);
    }
    function connectionMatches(connId, firstUid, secondUid, expectedStatus) {
      return exists(/databases/$(database)/documents/connections/$(connId)) &&
        get(/databases/$(database)/documents/connections/$(connId))
          .data.status == expectedStatus &&
        get(/databases/$(database)/documents/connections/$(connId))
          .data.participants is list &&
        get(/databases/$(database)/documents/connections/$(connId))
          .data.participants.size() == 2 &&
        get(/databases/$(database)/documents/connections/$(connId))
          .data.participants.hasAll([firstUid, secondUid]);
    }
    function hasConnectionStatus(firstUid, secondUid, expectedStatus) {
      return connectionMatches(
          firstUid + '_' + secondUid,
          firstUid,
          secondUid,
          expectedStatus
        ) || connectionMatches(
          secondUid + '_' + firstUid,
          firstUid,
          secondUid,
          expectedStatus
        );
    }
    function isAcceptedConnection(firstUid, secondUid) {
      return hasConnectionStatus(firstUid, secondUid, 'accepted');
    }
    // ¿`follower` sigue (aceptado) a `followee`?
    function isFollowing(follower, followee) {
      return exists(
          /databases/$(database)/documents/follows/$(follower + '_' + followee)
        ) &&
        get(/databases/$(database)/documents/follows/$(follower + '_' + followee))
          .data.status == 'accepted';
    }
    // ¿La cuenta de `uid` es privada? (users/{uid}.social.private)
    function accountIsPrivate(uid) {
      return exists(/databases/$(database)/documents/users/$(uid)) &&
        get(/databases/$(database)/documents/users/$(uid))
          .data.get('social', {}).get('private', false) == true;
    }
    function isBlockedConnection(firstUid, secondUid) {
      return hasConnectionStatus(firstUid, secondUid, 'blocked');
    }
    function isAvailableConquestPost(post) {
      return post.isDeleted == false &&
        post.isArchived == false &&
        post.moderationStatus == 'ok' &&
        (!post.keys().hasAny(['expiresAt']) ||
         post.expiresAt == null ||
         (post.expiresAt is timestamp && post.expiresAt > request.time));
    }
    function canReadConquestPost(post) {
      return post.userId == request.auth.uid ||
        (isAvailableConquestPost(post) &&
         !isBlockedConnection(request.auth.uid, post.userId) &&
         (post.visibility == 'public' ||
          (post.visibility == 'connections' &&
           (isAcceptedConnection(request.auth.uid, post.userId) ||
            isFollowing(request.auth.uid, post.userId)))));
    }
    function isActiveStory(post) {
      return post.expiresAt is timestamp &&
        post.expiresAt > request.time &&
        post.isDeleted == false &&
        post.isArchived == false &&
        post.moderationStatus == 'ok';
    }

    // ── Users ─────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isAuth();
      allow create: if isOwner(uid);
      // El usuario solo puede editar su propio perfil; ownerId solo desde server
      allow update: if isOwner(uid) &&
                       !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['capturedZones']);
    }

    // ── Zones ─────────────────────────────────────────────────────────────
    match /zones/{zoneId} {
      allow read: if isAuth();
      // La creación de zonas la hace el admin desde Firebase Console o seed script
      allow create: if false;
      // La captura la valida la Cloud Function; el cliente puede proponer pero
      // la escritura final debe venir del server. Por ahora permitimos update
      // para facilitar desarrollo — CAMBIAR A false EN PRODUCCIÓN
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Runs ──────────────────────────────────────────────────────────────
    match /runs/{runId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // runs son inmutables
    }

    // ── Announcements (tablón) ────────────────────────────────────────────
    // Solo lectura para usuarios autenticados; los crea el admin desde la
    // consola de Firebase (escritura denegada al cliente).
    match /announcements/{announcementId} {
      allow read:  if isAuth();
      allow write: if false;
    }

    // ── Clubs ─────────────────────────────────────────────────────────────
    match /clubs/{clubId} {
      allow read:   if isAuth();
      allow create: if isAuth()
                    && request.resource.data.adminId == request.auth.uid
                    // Nombre de club de al menos 3 caracteres (no se puede
                    // saltar desde el cliente).
                    && request.resource.data.name is string
                    && request.resource.data.name.size() >= 3;
      allow update: if isAuth() && (
        isClubAdmin(clubId) ||
        // Cualquier usuario autenticado puede añadirse como miembro
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
      );
      allow delete: if isClubAdmin(clubId);

      // ── Chat del club (subcolección) ────────────────────────────────────
      // Solo miembros del club pueden leer y escribir; mensajes inmutables.
      match /messages/{messageId} {
        allow read:   if isAuth() && isClubMember(clubId);
        allow create: if isAuth() && isClubMember(clubId) &&
                         request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ── Events (globales; visibles en club y, si isPublic, en el tablón) ───
    match /events/{eventId} {
      allow read: if isAuth() && (
        resource.data.isPublic == true || isClubMember(resource.data.clubId)
      );
      allow create: if isAuth()
        && request.resource.data.createdBy == request.auth.uid
        && isClubMember(request.resource.data.clubId);
      // Editar el evento: creador o admin del club.
      // Apuntarse/salir (solo cambia 'attendees'): cualquiera que pueda verlo.
      allow update: if isAuth() && (
        request.auth.uid == resource.data.createdBy ||
        isClubAdmin(resource.data.clubId) ||
        (onlyAttendeesChanged() &&
          (resource.data.isPublic == true || isClubMember(resource.data.clubId)))
      );
      allow delete: if isAuth() && (
        request.auth.uid == resource.data.createdBy ||
        isClubAdmin(resource.data.clubId)
      );
    }

    // ── Conexiones sociales ──────────────────────────────────────────────
    // Doc único por par (id = min_max). Solo los dos participantes lo ven/tocan;
    // nadie aprueba en nombre de otro ni accede a conexiones ajenas.
    match /connections/{connId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      // Crear: el solicitante es quien escribe y se incluye como participante.
      allow create: if isAuth()
        && request.resource.data.requesterUserId == request.auth.uid
        && request.resource.data.recipientUserId is string
        && request.resource.data.recipientUserId != request.auth.uid
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.resource.data.participants.hasAll([
          request.resource.data.requesterUserId,
          request.resource.data.recipientUserId
        ])
        && (connId == request.resource.data.requesterUserId + '_' +
              request.resource.data.recipientUserId ||
            connId == request.resource.data.recipientUserId + '_' +
              request.resource.data.requesterUserId)
        && request.resource.data.status == 'pending'
        && request.resource.data.source in [
          'stravaMatch', 'username', 'inviteLink', 'qr', 'challenge', 'club'
        ]
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.acceptedAt == null
        && request.resource.data.blockedAt == null
        && request.resource.data.blockedBy == null
        && request.resource.data.keys().hasOnly([
          'requesterUserId', 'recipientUserId', 'participants', 'status',
          'source', 'createdAt', 'updatedAt', 'acceptedAt', 'blockedAt',
          'blockedBy'
        ]);
      // Actualizar (aceptar/rechazar/eliminar/bloquear): solo un participante,
      // y sin cambiar quiénes participan.
      allow update: if isAuth()
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'requesterUserId', 'recipientUserId', 'status', 'source',
          'updatedAt', 'acceptedAt', 'blockedAt', 'blockedBy'
        ])
        && (connId == request.resource.data.requesterUserId + '_' +
              request.resource.data.recipientUserId ||
            connId == request.resource.data.recipientUserId + '_' +
              request.resource.data.requesterUserId)
        && (
          (
            request.resource.data.requesterUserId ==
              resource.data.requesterUserId
            && request.resource.data.recipientUserId ==
              resource.data.recipientUserId
            && request.resource.data.source == resource.data.source
            && (
              (resource.data.status == 'pending'
               && request.resource.data.status == 'accepted'
               && request.auth.uid == resource.data.recipientUserId
               && request.resource.data.acceptedAt is timestamp
               && request.resource.data.blockedAt == resource.data.blockedAt
               && request.resource.data.blockedBy == resource.data.blockedBy)
              ||
              (resource.data.status == 'pending'
               && request.resource.data.status == 'declined'
               && request.auth.uid == resource.data.recipientUserId
               && request.resource.data.acceptedAt == resource.data.acceptedAt
               && request.resource.data.blockedAt == resource.data.blockedAt
               && request.resource.data.blockedBy == resource.data.blockedBy)
              ||
              (resource.data.status != 'blocked'
               && request.resource.data.status == 'removed'
               && request.resource.data.acceptedAt == resource.data.acceptedAt
               && request.resource.data.blockedAt == resource.data.blockedAt
               && request.resource.data.blockedBy == resource.data.blockedBy)
              ||
              (resource.data.status != 'blocked'
               && request.resource.data.status == 'blocked'
               && request.resource.data.acceptedAt == resource.data.acceptedAt
               && request.resource.data.blockedAt is timestamp
               && request.resource.data.blockedBy == request.auth.uid)
            )
          )
          ||
          (
            resource.data.status in ['suggested', 'declined', 'removed']
            && request.resource.data.status == 'pending'
            && request.resource.data.requesterUserId == request.auth.uid
            && request.resource.data.recipientUserId != request.auth.uid
            && request.resource.data.participants.hasAll([
              request.resource.data.requesterUserId,
              request.resource.data.recipientUserId
            ])
            && request.resource.data.source in [
              'stravaMatch', 'username', 'inviteLink', 'qr', 'challenge', 'club'
            ]
            && request.resource.data.acceptedAt == resource.data.acceptedAt
            && request.resource.data.blockedAt == resource.data.blockedAt
            && request.resource.data.blockedBy == resource.data.blockedBy
          )
        );
      allow delete: if false; // no se borran; se marcan removed/blocked
    }

    // ── Seguidores (follow unidireccional) ───────────────────────────────
    // Doc follows/{followerId}_{followeeId}. Lo crea/borra el propio seguidor.
    // Cualquier autenticado puede leer (contadores de seguidores/seguidos).
    match /follows/{followId} {
      allow read: if isAuth();
      // Crear: el seguidor. Estado inicial 'pending' si la cuenta destino es
      // privada; 'accepted' si es pública (no puede autoconcederse 'accepted').
      allow create: if isAuth()
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.followeeId is string
        && request.resource.data.followeeId != request.auth.uid
        && followId == request.resource.data.followerId + '_' +
             request.resource.data.followeeId
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.keys().hasOnly([
          'followerId', 'followeeId', 'status', 'createdAt', 'updatedAt'
        ])
        && (
          (accountIsPrivate(request.resource.data.followeeId) &&
           request.resource.data.status == 'pending') ||
          (!accountIsPrivate(request.resource.data.followeeId) &&
           request.resource.data.status == 'accepted')
        );
      // Aprobar: solo el seguido pasa 'pending' → 'accepted'.
      allow update: if isAuth()
        && resource.data.followeeId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.status == 'accepted'
        && request.resource.data.followerId == resource.data.followerId
        && request.resource.data.followeeId == resource.data.followeeId
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'updatedAt']);
      // Borrar: el seguidor (dejar de seguir/cancelar) o el seguido (rechazar).
      allow delete: if isAuth() && (
        resource.data.followerId == request.auth.uid ||
        resource.data.followeeId == request.auth.uid
      );
    }

    // ── Retos privados ───────────────────────────────────────────────────
    // Solo participantes leen/tocan; el creador crea; nadie sin invitar entra.
    match /privateChallenges/{cid} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth()
        && request.resource.data.creatorId == request.auth.uid
        && request.auth.uid in request.resource.data.participants;
      allow update: if isAuth()
        && request.auth.uid in resource.data.participants;
      allow delete: if false;
    }

    // ── Zapatillas y enlaces (privados del dueño) ────────────────────────
    match /shoes/{shoeId} {
      allow read, delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow create, update: if isAuth()
        && request.resource.data.userId == request.auth.uid;
    }
    match /shoeActivityLinks/{linkId} {
      allow read, delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow create, update: if isAuth()
        && request.resource.data.userId == request.auth.uid;
    }

    // ── Conquistas (hito permanente del dueño) ───────────────────────────
    match /zone_conquests/{cid} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create, update: if isAuth()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if false; // borrado lógico (isDeleted), no físico
    }

    // ── Publicaciones de conquista ───────────────────────────────────────
    match /conquest_posts/{pid} {
      // Lee el dueño; o cualquiera si es pública, activa y visible.
      // El documento bruto puede contener snapshots privados. Terceros usan
      // getConquestFeed/getConquestDetail, que devuelven un DTO saneado.
      allow get: if isAuth() &&
        (resource.data.userId == request.auth.uid || isModerator());
      // Los feeds de terceros pasan por getConquestFeed.
      allow list: if isAuth() && resource.data.userId == request.auth.uid;
      // Crear: el dueño, con contadores a cero y moderación 'ok'.
      allow create: if isAuth()
        && request.resource.data.keys().hasAll([
          'userId', 'type', 'visibility', 'createdAt', 'updatedAt', 'caption',
          'isArchived', 'isDeleted', 'locationPrivacyMode', 'likesCount',
          'applauseCount', 'commentsCount', 'reportCount', 'moderationStatus'
        ])
        && request.resource.data.userId is string
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.type in [
          'photo', 'selfie', 'text', 'story', 'achievementShare',
          'zoneConquest', 'activityMoment'
        ]
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.caption is string
        && request.resource.data.caption.size() <= 200
        && request.resource.data.isArchived == false
        && request.resource.data.isDeleted == false
        && request.resource.data.locationPrivacyMode in [
          'fullZone', 'neighborhood', 'city', 'none'
        ]
        && request.resource.data.likesCount == 0
        && request.resource.data.get('applauseCount', 0) == 0
        && request.resource.data.commentsCount == 0
        && request.resource.data.reportCount == 0
        && request.resource.data.moderationStatus == 'ok'
        && request.resource.data.visibility in [
          'onlyMe', 'connections', 'public'
        ]
        && !request.resource.data.keys().hasAny([
          'moderatedAt', 'moderatedBy'
        ])
        // Una historia debe caducar en el futuro y no puede superar 25 h.
        && (!request.resource.data.keys().hasAny(['expiresAt']) ||
            request.resource.data.expiresAt == null ||
            (request.resource.data.expiresAt is timestamp &&
             request.resource.data.expiresAt > request.time &&
             request.resource.data.expiresAt <=
               request.time + duration.value(25, 'h')));
      // Editar: el dueño solo puede cambiar estos campos de usuario.
      allow update: if isAuth()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'visibility', 'caption', 'isArchived', 'isDeleted', 'updatedAt'
        ])
        && request.resource.data.caption is string
        && request.resource.data.caption.size() <= 200
        && request.resource.data.isArchived is bool
        && request.resource.data.isDeleted is bool
        && request.resource.data.updatedAt == request.time
        && request.resource.data.likesCount == resource.data.likesCount
        && request.resource.data.get('applauseCount', 0) ==
          resource.data.get('applauseCount', 0)
        && request.resource.data.commentsCount == resource.data.commentsCount
        && request.resource.data.reportCount == resource.data.reportCount
        && request.resource.data.moderationStatus == resource.data.moderationStatus
        && request.resource.data.visibility in [
          'onlyMe', 'connections', 'public'
        ];
      allow delete: if false; // borrado lógico

      // Una vista por usuario e historia. El UID es el ID determinista.
      // Una reaccion por usuario. Solo el backend cambia reacciones/contadores.
      match /reactions/{reactionUserId} {
        allow get: if isAuth()
          && exists(/databases/$(database)/documents/conquest_posts/$(pid))
          && canReadConquestPost(
            get(/databases/$(database)/documents/conquest_posts/$(pid)).data
          )
          && (reactionUserId == request.auth.uid ||
              get(/databases/$(database)/documents/conquest_posts/$(pid))
                .data.userId == request.auth.uid);
        allow list: if isAuth()
          && exists(/databases/$(database)/documents/conquest_posts/$(pid))
          && get(/databases/$(database)/documents/conquest_posts/$(pid))
            .data.userId == request.auth.uid;
        allow create, update, delete: if false;
      }

      // Comentarios visibles; creacion y borrado logico solo por callable.
      match /comments/{commentId} {
        allow get: if isAuth()
          && exists(/databases/$(database)/documents/conquest_posts/$(pid))
          && canReadConquestPost(
            get(/databases/$(database)/documents/conquest_posts/$(pid)).data
          )
          && (
            (resource.data.isDeleted == false &&
             resource.data.moderationStatus == 'ok') ||
            resource.data.authorId == request.auth.uid ||
            get(/databases/$(database)/documents/conquest_posts/$(pid))
              .data.userId == request.auth.uid
          );
        allow list: if isAuth()
          && exists(/databases/$(database)/documents/conquest_posts/$(pid))
          && canReadConquestPost(
            get(/databases/$(database)/documents/conquest_posts/$(pid)).data
          )
          && (
            get(/databases/$(database)/documents/conquest_posts/$(pid))
              .data.userId == request.auth.uid ||
            (resource.data.isDeleted == false &&
             resource.data.moderationStatus == 'ok')
          );
        allow create, update, delete: if false;
      }

      // Los reportes no se enumeran desde el cliente salvo moderadores.
      match /reports/{reporterId} {
        allow get: if isAuth() &&
          (reporterId == request.auth.uid || isModerator());
        allow list: if isModerator();
        allow create, update, delete: if false;
      }

      match /story_views/{viewerId} {
        allow create: if isAuth()
          && viewerId == request.auth.uid
          && exists(/databases/$(database)/documents/conquest_posts/$(pid))
          && isActiveStory(
            get(/databases/$(database)/documents/conquest_posts/$(pid)).data
          )
          && canReadConquestPost(
            get(/databases/$(database)/documents/conquest_posts/$(pid)).data
          )
          && request.auth.uid !=
            get(/databases/$(database)/documents/conquest_posts/$(pid)).data.userId
          && request.resource.data.keys().hasOnly([
            'storyId', 'viewerId', 'viewedAt'
          ])
          && request.resource.data.storyId == pid
          && request.resource.data.viewerId == request.auth.uid
          && request.resource.data.viewedAt == request.time;

        // El espectador comprueba su propia vista; el autor puede ver la lista.
        allow get: if isAuth() && (
          viewerId == request.auth.uid ||
          (exists(/databases/$(database)/documents/conquest_posts/$(pid)) &&
           get(/databases/$(database)/documents/conquest_posts/$(pid)).data.userId ==
             request.auth.uid)
        );
        allow list: if isAuth()
          && exists(/databases/$(database)/documents/conquest_posts/$(pid))
          && get(/databases/$(database)/documents/conquest_posts/$(pid)).data.userId ==
            request.auth.uid;
        allow update, delete: if false;
      }
    }
  }
}
