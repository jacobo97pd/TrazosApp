rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────
    function isAuth()          { return request.auth != null; }
    function isOwner(uid)      { return request.auth.uid == uid; }
    function isClubAdmin(clubId) {
      return get(/databases/$(database)/documents/clubs/$(clubId))
               .data.adminId == request.auth.uid;
    }
    function isClubMember(clubId) {
      return request.auth.uid in
        get(/databases/$(database)/documents/clubs/$(clubId)).data.members;
    }
    function onlyAttendeesChanged() {
      return request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['attendees']);
    }

    // ── Users ─────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isAuth();
      allow create: if isOwner(uid);
      // El usuario solo puede editar su propio perfil; ownerId solo desde server
      allow update: if isOwner(uid) &&
                       !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['capturedZones']);
    }

    // ── Zones ─────────────────────────────────────────────────────────────
    match /zones/{zoneId} {
      allow read: if isAuth();
      // La creación de zonas la hace el admin desde Firebase Console o seed script
      allow create: if false;
      // La captura la valida la Cloud Function; el cliente puede proponer pero
      // la escritura final debe venir del server. Por ahora permitimos update
      // para facilitar desarrollo — CAMBIAR A false EN PRODUCCIÓN
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Runs ──────────────────────────────────────────────────────────────
    match /runs/{runId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // runs son inmutables
    }

    // ── Announcements (tablón) ────────────────────────────────────────────
    // Solo lectura para usuarios autenticados; los crea el admin desde la
    // consola de Firebase (escritura denegada al cliente).
    match /announcements/{announcementId} {
      allow read:  if isAuth();
      allow write: if false;
    }

    // ── Clubs ─────────────────────────────────────────────────────────────
    match /clubs/{clubId} {
      allow read:   if isAuth();
      allow create: if isAuth()
                    && request.resource.data.adminId == request.auth.uid
                    // Nombre de club de al menos 3 caracteres (no se puede
                    // saltar desde el cliente).
                    && request.resource.data.name is string
                    && request.resource.data.name.size() >= 3;
      allow update: if isAuth() && (
        isClubAdmin(clubId) ||
        // Cualquier usuario autenticado puede añadirse como miembro
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
      );
      allow delete: if isClubAdmin(clubId);

      // ── Chat del club (subcolección) ────────────────────────────────────
      // Solo miembros del club pueden leer y escribir; mensajes inmutables.
      match /messages/{messageId} {
        allow read:   if isAuth() && isClubMember(clubId);
        allow create: if isAuth() && isClubMember(clubId) &&
                         request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ── Events (globales; visibles en club y, si isPublic, en el tablón) ───
    match /events/{eventId} {
      allow read: if isAuth() && (
        resource.data.isPublic == true || isClubMember(resource.data.clubId)
      );
      allow create: if isAuth()
        && request.resource.data.createdBy == request.auth.uid
        && isClubMember(request.resource.data.clubId);
      // Editar el evento: creador o admin del club.
      // Apuntarse/salir (solo cambia 'attendees'): cualquiera que pueda verlo.
      allow update: if isAuth() && (
        request.auth.uid == resource.data.createdBy ||
        isClubAdmin(resource.data.clubId) ||
        (onlyAttendeesChanged() &&
          (resource.data.isPublic == true || isClubMember(resource.data.clubId)))
      );
      allow delete: if isAuth() && (
        request.auth.uid == resource.data.createdBy ||
        isClubAdmin(resource.data.clubId)
      );
    }

    // ── Conexiones sociales ──────────────────────────────────────────────
    // Doc único por par (id = min_max). Solo los dos participantes lo ven/tocan;
    // nadie aprueba en nombre de otro ni accede a conexiones ajenas.
    match /connections/{connId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      // Crear: el solicitante es quien escribe y se incluye como participante.
      allow create: if isAuth()
        && request.resource.data.requesterUserId == request.auth.uid
        && request.auth.uid in request.resource.data.participants;
      // Actualizar (aceptar/rechazar/eliminar/bloquear): solo un participante,
      // y sin cambiar quiénes participan.
      allow update: if isAuth()
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants;
      allow delete: if false; // no se borran; se marcan removed/blocked
    }

    // ── Retos privados ───────────────────────────────────────────────────
    // Solo participantes leen/tocan; el creador crea; nadie sin invitar entra.
    match /privateChallenges/{cid} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth()
        && request.resource.data.creatorId == request.auth.uid
        && request.auth.uid in request.resource.data.participants;
      allow update: if isAuth()
        && request.auth.uid in resource.data.participants;
      allow delete: if false;
    }

    // ── Zapatillas y enlaces (privados del dueño) ────────────────────────
    match /shoes/{shoeId} {
      allow read, delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow create, update: if isAuth()
        && request.resource.data.userId == request.auth.uid;
    }
    match /shoeActivityLinks/{linkId} {
      allow read, delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow create, update: if isAuth()
        && request.resource.data.userId == request.auth.uid;
    }

    // ── Conquistas (hito permanente del dueño) ───────────────────────────
    match /zone_conquests/{cid} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create, update: if isAuth()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if false; // borrado lógico (isDeleted), no físico
    }

    // ── Publicaciones de conquista ───────────────────────────────────────
    match /conquest_posts/{pid} {
      // Lee el dueño; o cualquiera si es pública, no borrada y visible.
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        (resource.data.visibility == 'public' &&
         resource.data.isDeleted == false &&
         resource.data.moderationStatus == 'ok')
      );
      // Crear: el dueño, con contadores a cero y moderación 'ok'.
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.likesCount == 0
        && request.resource.data.commentsCount == 0
        && request.resource.data.reportCount == 0
        && request.resource.data.moderationStatus == 'ok';
      // Editar: el dueño, sin tocar contadores ni estado de moderación.
      allow update: if isAuth()
        && resource.data.userId == request.auth.uid
        && request.resource.data.likesCount == resource.data.likesCount
        && request.resource.data.commentsCount == resource.data.commentsCount
        && request.resource.data.reportCount == resource.data.reportCount
        && request.resource.data.moderationStatus == resource.data.moderationStatus;
      allow delete: if false; // borrado lógico
    }
  }
}
